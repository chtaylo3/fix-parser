{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "vs2022",
      "displayName": "MSVC (Visual Studio 17 2022, x64)",
      "inherits": "vcpkg-base",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "vs2022-x86",
      "displayName": "MSVC (Visual Studio 17 2022, Win32/x86) — packaging",
      "inherits": "vcpkg-base",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows-static",
        "VCPKG_MANIFEST_FEATURES": "",
        "FIXPARSER_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "ninja",
      "displayName": "MSVC (Ninja, x64) — run from a Developer Command Prompt",
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "ci",
      "displayName": "CI (Ninja Multi-Config, MSVC, x64-windows-static)",
      "description": "Version-agnostic CI generator — needs the MSVC env on PATH (dev shell).",
      "inherits": "vcpkg-base",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "FIXPARSER_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "ci-x86",
      "displayName": "CI x86 (Ninja Multi-Config, MSVC, x86-windows-static)",
      "description": "Version-agnostic x86 plugin build — run from an x86 MSVC dev shell.",
      "inherits": "vcpkg-base",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows-static",
        "VCPKG_MANIFEST_FEATURES": "",
        "FIXPARSER_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "sanitize",
      "displayName": "Sanitizer (MSVC ASan, x64)",
      "description": "Build + run the Catch2 tests under AddressSanitizer. (UBSan needs clang-cl, which has Windows runtime-linking friction; see sanitize-clang.)",
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "FIXPARSER_ENABLE_SANITIZERS": "ON",
        "FIXPARSER_BUILD_TESTS": "ON",
        "FIXPARSER_BUILD_PLUGIN": "OFF"
      }
    },
    {
      "name": "tidy",
      "displayName": "clang-tidy (core)",
      "description": "Lint the parser core with clang-tidy during build. Needs clang-tidy (LLVM) on PATH.",
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "FIXPARSER_ENABLE_CLANG_TIDY": "ON",
        "FIXPARSER_BUILD_PLUGIN": "OFF",
        "FIXPARSER_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "fuzz",
      "displayName": "libFuzzer (clang-cl, fuzzer+ASan)",
      "description": "Coverage-guided fuzzer for the parser core. Needs LLVM (clang-cl) and the MSVC env on PATH.",
      "inherits": "vcpkg-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "FIXPARSER_BUILD_FUZZER": "ON",
        "FIXPARSER_BUILD_PLUGIN": "OFF",
        "FIXPARSER_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-debug",
      "configurePreset": "vs2022",
      "configuration": "Debug"
    },
    {
      "name": "vs2022-release",
      "configurePreset": "vs2022",
      "configuration": "Release"
    },
    {
      "name": "vs2022-x86-release",
      "configurePreset": "vs2022-x86",
      "configuration": "Release"
    },
    {
      "name": "ninja",
      "configurePreset": "ninja"
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci",
      "configuration": "Debug"
    },
    {
      "name": "ci-release",
      "configurePreset": "ci",
      "configuration": "Release"
    },
    {
      "name": "ci-x86-release",
      "configurePreset": "ci-x86",
      "configuration": "Release"
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize"
    },
    {
      "name": "tidy",
      "configurePreset": "tidy"
    },
    {
      "name": "fuzz",
      "configurePreset": "fuzz"
    }
  ],
  "testPresets": [
    {
      "name": "vs2022-debug",
      "configurePreset": "vs2022",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ninja",
      "configurePreset": "ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-release",
      "configurePreset": "ci",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
