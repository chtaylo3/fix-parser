// Generated from version.rc.in by CMake configure_file (@ONLY). Do not edit the
// generated copy under the build tree -- edit the template.
//
// Embeds VERSIONINFO into FixParser.dll. Notepad++'s Plugins Admin (nppPluginList
// validator.py) REQUIRES a DLL with embedded version information whose FILEVERSION
// equals the manifest version padded to four parts (e.g. 0.1.0 -> 0.1.0.0).
#include <windows.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS      VS_FF_DEBUG
#else
 FILEFLAGS      0x0L
#endif
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_DLL
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "chtaylo3 (github.com/chtaylo3)"
            VALUE "FileDescription",  "FixParser - Notepad++ plugin to pretty-print and inspect FIX protocol logs"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "FixParser"
            VALUE "LegalCopyright",   "Copyright (C) 2026 Chris Taylor. GPL-2.0."
            VALUE "OriginalFilename", "FixParser.dll"
            VALUE "ProductName",      "FixParser"
            VALUE "ProductVersion",   "@PROJECT_VERSION@.0"
            VALUE "Comments",         "https://github.com/chtaylo3/fix-parser"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        // 0x0409 = U.S. English, 1200 (0x04b0) = Unicode.
        VALUE "Translation", 0x409, 1200
    END
END
